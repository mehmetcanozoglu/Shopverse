import { useState } from 'react';

const Checkout = ({ cart, totalPrice, clearCart, setCurrentPage }) => {
  const [formData, setFormData] = useState({ fullName: '', email: '', address: '', city: '', zipCode: '', cardNumber: '', expiryDate: '', cvv: '' });
  const [isProcessing, setIsProcessing] = useState(false);
  const [isSuccess, setIsSuccess] = useState(false);

  const handleSubmit = (e) => {
    e.preventDefault();
    setIsProcessing(true);
    setTimeout(() => { setIsProcessing(false); setIsSuccess(true); clearCart(); setTimeout(() => setCurrentPage('home'), 3000); }, 2000);
  };

  if (isSuccess) return <div className="text-center py-20"><span className="text-6xl">🎉</span><h2 className="text-3xl font-bold mt-4">Order Successful!</h2><p className="text-gray-600 mt-2">Thank you for your purchase.</p></div>;

  return (
    <div className="max-w-7xl mx-auto px-4 py-12">
      <button onClick={() => setCurrentPage('home')} className="mb-6 text-gray-600 hover:text-orange-500">← Back to Shopping</button>
      <div className="grid md:grid-cols-3 gap-8">
        <div className="md:col-span-2 bg-white rounded-2xl shadow-sm p-6">
          <h2 className="text-2xl font-bold mb-6">Checkout</h2>
          <form onSubmit={handleSubmit} className="space-y-4">
            <input type="text" name="fullName" placeholder="Full Name" required onChange={(e) => setFormData({...formData, fullName: e.target.value})} className="w-full px-4 py-3 border rounded-lg" />
            <input type="email" name="email" placeholder="Email" required onChange={(e) => setFormData({...formData, email: e.target.value})} className="w-full px-4 py-3 border rounded-lg" />
            <input type="text" name="address" placeholder="Address" required onChange={(e) => setFormData({...formData, address: e.target.value})} className="w-full px-4 py-3 border rounded-lg" />
            <div className="grid grid-cols-2 gap-4"><input type="text" name="city" placeholder="City" required onChange={(e) => setFormData({...formData, city: e.target.value})} className="px-4 py-3 border rounded-lg" /><input type="text" name="zipCode" placeholder="Zip Code" required onChange={(e) => setFormData({...formData, zipCode: e.target.value})} className="px-4 py-3 border rounded-lg" /></div>
            <div className="border-t pt-4"><h3 className="font-bold mb-4">Payment Information</h3><input type="text" name="cardNumber" placeholder="Card Number" required onChange={(e) => setFormData({...formData, cardNumber: e.target.value})} className="w-full px-4 py-3 border rounded-lg mb-4" /><div className="grid grid-cols-2 gap-4"><input type="text" name="expiryDate" placeholder="MM/YY" required onChange={(e) => setFormData({...formData, expiryDate: e.target.value})} className="px-4 py-3 border rounded-lg" /><input type="password" name="cvv" placeholder="CVV" required onChange={(e) => setFormData({...formData, cvv: e.target.value})} className="px-4 py-3 border rounded-lg" /></div></div>
            <button type="submit" disabled={isProcessing} className="w-full bg-green-500 text-white py-4 rounded-xl font-bold text-lg">{isProcessing ? 'Processing...' : `Pay $${totalPrice.toLocaleString()}`}</button>
          </form>
        </div>
        <div className="bg-gray-50 rounded-2xl p-6 h-fit"><h3 className="text-xl font-bold mb-4">Order Summary</h3><div className="space-y-3 max-h-80 overflow-y-auto">{cart.map((item) => (<div key={item.id} className="flex justify-between text-sm"><span>{item.name} x {item.quantity}</span><span>${(item.price * item.quantity).toLocaleString()}</span></div>))}</div><div className="border-t mt-4 pt-4"><div className="flex justify-between font-bold text-lg"><span>Total:</span><span className="text-orange-500">${totalPrice.toLocaleString()}</span></div></div></div>
      </div>
    </div>
  );
};

export default Checkout;
</file>

