<file path="src/components/Cart.jsx">
const Cart = ({ isOpen, setIsOpen, cart, updateQuantity, removeFromCart, setCurrentPage }) => {
  // Toplam fiyatı anlık hesapla
  const calculateTotal = () => {
    return cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
  };

  const handleCheckout = () => {
    setIsOpen(false);
    setCurrentPage('checkout');
  };

  return (
    <>
      {isOpen && <div className="fixed inset-0 bg-black/50 z-40" onClick={() => setIsOpen(false)} />}
      
      <div className={`fixed right-0 top-0 w-full max-w-md h-full bg-white shadow-2xl z-50 flex flex-col transition-all duration-300 ${isOpen ? 'translate-x-0' : 'translate-x-full'}`}>
        <div className="flex justify-between items-center p-5 border-b bg-orange-50">
          <h2 className="text-xl font-bold">🛒 My Cart ({cart.reduce((s,i)=>s+i.quantity,0)} items)</h2>
          <button onClick={() => setIsOpen(false)} className="text-2xl hover:text-orange-500">✕</button>
        </div>

        <div className="flex-1 overflow-y-auto p-5 space-y-4">
          {cart.length === 0 ? (
            <div className="text-center py-20">
              <span className="text-7xl">🛒</span>
              <p className="text-gray-500 mt-4">Your cart is empty</p>
              <button onClick={() => setIsOpen(false)} className="mt-6 text-orange-500 font-semibold underline">Continue Shopping →</button>
            </div>
          ) : (
            cart.map((item) => (
              <div key={item.id} className="flex gap-3 border-b pb-4">
                <img src={item.image} alt={item.name} className="w-20 h-20 object-cover rounded-lg" />
                <div className="flex-1">
                  <h3 className="font-semibold text-sm mb-1">{item.name}</h3>
                  <p className="text-orange-500 font-bold">${item.price}</p>
                  <div className="flex items-center gap-3 mt-2">
                    <button 
                      onClick={() => updateQuantity(item.id, -1)} 
                      className="w-7 h-7 bg-gray-100 rounded-full hover:bg-gray-200 font-bold text-lg"
                    >
                      −
                    </button>
                    <span className="text-sm font-medium min-w-[30px] text-center">{item.quantity}</span>
                    <button 
                      onClick={() => updateQuantity(item.id, 1)} 
                      className="w-7 h-7 bg-gray-100 rounded-full hover:bg-gray-200 font-bold text-lg"
                    >
                      +
                    </button>
                    <button 
                      onClick={() => removeFromCart(item.id)} 
                      className="text-red-500 text-xs ml-auto hover:underline"
                    >
                      Remove
                    </button>
                  </div>
                  {/* Ürün bazlı toplam fiyat - anlık gösterim */}
                  <div className="text-right text-xs font-semibold text-orange-600 mt-1">
                    ${(item.price * item.quantity).toLocaleString()}
                  </div>
                </div>
              </div>
            ))
          )}
        </div>

        {cart.length > 0 && (
          <div className="border-t p-5 space-y-3 bg-gray-50">
            <div className="space-y-2">
              <div className="flex justify-between text-sm">
                <span>Subtotal:</span>
                <span>${calculateTotal().toLocaleString()}</span>
              </div>
              <div className="flex justify-between text-sm">
                <span>Shipping:</span>
                <span className="text-green-600">Free</span>
              </div>
              <div className="border-t pt-2 flex justify-between text-xl font-bold">
                <span>Total:</span>
                <span className="text-orange-500">${calculateTotal().toLocaleString()}</span>
              </div>
            </div>
            <button onClick={handleCheckout} className="w-full bg-green-500 text-white py-3 rounded-lg font-semibold hover:bg-green-600 transition">
              Checkout ✅
            </button>
            <button onClick={() => setIsOpen(false)} className="w-full text-gray-500 text-sm hover:text-orange-500 transition">
              ← Continue Shopping
            </button>
          </div>
        )}
      </div>
    </>
  );
};

export default Cart;
</file>

