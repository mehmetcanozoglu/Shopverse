import { useState } from 'react';
import Header from './components/Header';
import ProductCard from './components/ProductCard';
import Cart from './components/Cart';
import Footer from './components/Footer';
import ProductDetail from './pages/ProductDetail';
import Checkout from './pages/Checkout';

function App() {
  const [products] = useState([
    { id: 1, name: "Apple AirPods Pro 2", price: 399, oldPrice: 499, rating: 4.8, reviews: 12450, image: "https://images.pexels.com/photos/3394650/pexels-photo-3394650.jpeg", badge: "Best Seller", category: "Electronics", brand: "Apple" },
    { id: 2, name: "Samsung Galaxy Watch 6", price: 299, oldPrice: 399, rating: 4.7, reviews: 8920, image: "https://images.pexels.com/photos/437037/pexels-photo-437037.jpeg", badge: "Flash Deal", category: "Electronics", brand: "Samsung" },
    { id: 3, name: "Nike Air Max 270", price: 159, oldPrice: 249, rating: 4.9, reviews: 5670, image: "https://images.pexels.com/photos/2529148/pexels-photo-2529148.jpeg", badge: "Trending", category: "Fashion", brand: "Nike" },
    { id: 4, name: "Dyson V15 Detect", price: 899, oldPrice: 1199, rating: 4.8, reviews: 2340, image: "https://images.pexels.com/photos/3859979/pexels-photo-3859979.jpeg", badge: "Premium", category: "Home", brand: "Dyson" },
    { id: 5, name: "iPhone 15 Pro Max", price: 1499, oldPrice: 1699, rating: 4.9, reviews: 15670, image: "https://images.pexels.com/photos/788946/pexels-photo-788946.jpeg", badge: "New", category: "Electronics", brand: "Apple" },
    { id: 6, name: "Sony WH-1000XM5", price: 449, oldPrice: 549, rating: 4.9, reviews: 8920, image: "https://images.pexels.com/photos/3394650/pexels-photo-3394650.jpeg", badge: "Top Rated", category: "Electronics", brand: "Sony" },
    { id: 7, name: "Adidas Ultraboost", price: 179, oldPrice: 229, rating: 4.7, reviews: 3450, image: "https://images.pexels.com/photos/1598508/pexels-photo-1598508.jpeg", badge: "Hot Deal", category: "Fashion", brand: "Adidas" },
    { id: 8, name: "MacBook Pro M3", price: 1999, oldPrice: 2299, rating: 4.9, reviews: 5670, image: "https://images.pexels.com/photos/18105/pexels-photo.jpg", badge: "Premium", category: "Electronics", brand: "Apple" },
    { id: 9, name: "Zara Wool Jacket", price: 89, oldPrice: 149, rating: 4.6, reviews: 2340, image: "https://images.pexels.com/photos/1152077/pexels-photo-1152077.jpeg", badge: "Sale", category: "Fashion", brand: "Zara" },
    { id: 10, name: "Xiaomi Robot Vacuum", price: 249, oldPrice: 399, rating: 4.7, reviews: 4120, image: "https://images.pexels.com/photos/4107282/pexels-photo-4107282.jpeg", badge: "Smart", category: "Home", brand: "Xiaomi" }
  ]);

  const [cart, setCart] = useState([]);
  const [currentPage, setCurrentPage] = useState('home');
  const [selectedProduct, setSelectedProduct] = useState(null);
  const [sortBy, setSortBy] = useState("default");
  const [selectedCategory, setSelectedCategory] = useState("all");
  const [isCartOpen, setIsCartOpen] = useState(false);

  // Sepete ekle
  const addToCart = (product) => {
    setCart(prevCart => {
      const existing = prevCart.find(item => item.id === product.id);
      if (existing) {
        return prevCart.map(item =>
          item.id === product.id ? { ...item, quantity: item.quantity + 1 } : item
        );
      }
      return [...prevCart, { ...product, quantity: 1 }];
    });
  };

  // Adet güncelle - BURASI ÖNEMLİ
  // Bu fonksiyon App.jsx'te - ÇALIŞIYOR
const updateQuantity = (id, delta) => {
  setCart(prevCart => {
    const newCart = [...prevCart];
    const itemIndex = newCart.findIndex(item => item.id === id);
    
    if (itemIndex !== -1) {
      const currentQty = newCart[itemIndex].quantity;
      const newQty = currentQty + delta;
      
      if (newQty > 0) {
        newCart[itemIndex] = { ...newCart[itemIndex], quantity: newQty };
      } else {
        newCart.splice(itemIndex, 1);
      }
    }
    
    return newCart;
  });
};
  // Sepetten sil
  const removeFromCart = (id) => {
    setCart(prevCart => prevCart.filter(item => item.id !== id));
  };

  // Sepeti temizle
  const clearCart = () => {
    setCart([]);
  };

  // Kategoriler
  const categories = ["all", ...new Set(products.map(p => p.category))];
  
  // Filtreleme
  const filteredProducts = products
    .filter(p => selectedCategory === "all" || p.category === selectedCategory)
    .sort((a, b) => {
      if (sortBy === "price_asc") return a.price - b.price;
      if (sortBy === "price_desc") return b.price - a.price;
      if (sortBy === "rating") return b.rating - a.rating;
      return 0;
    });

  // Sepet özeti - ANLIK HESAPLANIYOR
  const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
  const totalPrice = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);

  // Sayfalar
  const CouponsPage = () => (
    <div className="max-w-7xl mx-auto px-4 py-20 text-center">
      <span className="text-6xl">🏷️</span>
      <h1 className="text-3xl font-bold mt-4 mb-2">Discount Coupons</h1>
      <p className="text-gray-600">Get exclusive discounts and promo codes here!</p>
      <div className="grid md:grid-cols-3 gap-4 mt-8 max-w-2xl mx-auto">
        <div className="bg-orange-50 p-6 rounded-xl"><span className="text-2xl">🎉</span><h3 className="font-bold mt-2">WELCOME20</h3><p className="text-sm text-gray-500">20% off first order</p></div>
        <div className="bg-green-50 p-6 rounded-xl"><span className="text-2xl">🚚</span><h3 className="font-bold mt-2">FREESHIP</h3><p className="text-sm text-gray-500">Free shipping over $50</p></div>
        <div className="bg-blue-50 p-6 rounded-xl"><span className="text-2xl">⭐</span><h3 className="font-bold mt-2">SUMMER30</h3><p className="text-sm text-gray-500">30% off summer collection</p></div>
      </div>
    </div>
  );

  const SellPage = () => (
    <div className="max-w-7xl mx-auto px-4 py-20 text-center">
      <span className="text-6xl">📦</span>
      <h1 className="text-3xl font-bold mt-4 mb-2">Sell on ShopVerse</h1>
      <p className="text-gray-600">Reach millions of customers worldwide</p>
      <button className="mt-8 bg-orange-500 text-white px-8 py-3 rounded-full font-semibold">Start Selling →</button>
    </div>
  );

  const AboutPage = () => (
    <div className="max-w-7xl mx-auto px-4 py-20 text-center">
      <span className="text-6xl">📖</span>
      <h1 className="text-3xl font-bold mt-4 mb-2">About ShopVerse</h1>
      <p className="text-gray-600 max-w-2xl mx-auto">ShopVerse is your premier destination for quality products at unbeatable prices.</p>
    </div>
  );

  return (
    <div className="min-h-screen bg-gray-50">
      <Header 
        setIsCartOpen={setIsCartOpen}
        totalItems={totalItems}
        setCurrentPage={setCurrentPage}
        currentPage={currentPage}
      />
      
      {currentPage === 'home' && (
        <main className="max-w-7xl mx-auto px-4 py-8">
          <div className="bg-gradient-to-r from-orange-500 to-red-500 rounded-2xl p-8 mb-8 text-white">
            <h1 className="text-3xl md:text-4xl font-bold mb-2">Summer Sale!</h1>
            <p className="text-lg mb-4">Up to 70% OFF on selected items</p>
            <button className="bg-white text-orange-500 px-6 py-2 rounded-full font-semibold">Shop Now →</button>
          </div>

          <div className="flex gap-2 overflow-x-auto pb-4 mb-6">
            {categories.map(cat => (
              <button key={cat} onClick={() => setSelectedCategory(cat)} className={`px-4 py-2 rounded-full text-sm font-medium whitespace-nowrap ${selectedCategory === cat ? "bg-orange-500 text-white" : "bg-gray-200 text-gray-700"}`}>
                {cat === "all" ? "All" : cat} ({products.filter(p => cat === "all" || p.category === cat).length})
              </button>
            ))}
          </div>

          <div className="flex justify-between items-center mb-6">
            <p className="text-gray-500">{filteredProducts.length} products</p>
            <select value={sortBy} onChange={(e) => setSortBy(e.target.value)} className="px-4 py-2 border rounded-lg text-sm">
              <option value="default">Sort by: Featured</option>
              <option value="price_asc">Price: Low to High</option>
              <option value="price_desc">Price: High to Low</option>
              <option value="rating">Highest Rated</option>
            </select>
          </div>

          <div className="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-5">
            {filteredProducts.map(product => (
              <ProductCard key={product.id} product={product} addToCart={addToCart} setCurrentPage={setCurrentPage} setSelectedProduct={setSelectedProduct} />
            ))}
          </div>
          {filteredProducts.length === 0 && <div className="text-center py-20">No products found</div>}
        </main>
      )}
      
      {currentPage === 'product' && <ProductDetail product={selectedProduct} addToCart={addToCart} setCurrentPage={setCurrentPage} />}
      {currentPage === 'checkout' && <Checkout cart={cart} totalPrice={totalPrice} clearCart={clearCart} setCurrentPage={setCurrentPage} />}
      {currentPage === 'coupons' && <CouponsPage />}
      {currentPage === 'sell' && <SellPage />}
      {currentPage === 'about' && <AboutPage />}
      
      <Footer setCurrentPage={setCurrentPage} />
      
      <Cart 
        isOpen={isCartOpen}
        setIsOpen={setIsCartOpen}
        cart={cart}
        updateQuantity={updateQuantity}
        removeFromCart={removeFromCart}
        totalPrice={totalPrice}
        setCurrentPage={setCurrentPage}
      />
    </div>
  );
}

export default App;
</file>

