<file path="src/pages/ProductDetail.jsx">
import { useState } from 'react';

const ProductDetail = ({ product, addToCart, setCurrentPage }) => {
  const [quantity, setQuantity] = useState(1);
  
  if (!product) return <div className="text-center py-20">Product not found</div>;

  const discountPercent = Math.round(((product.oldPrice - product.price) / product.oldPrice) * 100);
  
  // ANLIK FİYAT GÖSTERİMİ - quantity değişince fiyat değişir
  const currentTotalPrice = product.price * quantity;
  
  const handleAddToCart = () => { 
    for(let i = 0; i < quantity; i++) { 
      addToCart(product); 
    }
    alert(`${quantity} x ${product.name} added to cart!`);
    setQuantity(1); // sepete ekledikten sonra quantity'yi sıfırla
  };
  
  const handleBuyNow = () => { 
    for(let i = 0; i < quantity; i++) { 
      addToCart(product); 
    }
    setCurrentPage('checkout'); 
  };

  return (
    <div className="max-w-7xl mx-auto px-4 py-12">
      <button onClick={() => setCurrentPage('home')} className="mb-6 text-gray-600 hover:text-orange-500">← Back to Shopping</button>
      
      <div className="grid md:grid-cols-2 gap-12">
        <div className="bg-gray-100 rounded-2xl overflow-hidden">
          <img src={product.image} alt={product.name} className="w-full h-auto object-cover" />
        </div>
        
        <div>
          <div className="flex gap-2 mb-4">
            {discountPercent > 0 && <span className="bg-red-500 text-white px-3 py-1 rounded-full text-sm font-bold">-{discountPercent}%</span>}
            {product.badge && <span className="bg-orange-500 text-white px-3 py-1 rounded-full text-sm font-bold">{product.badge}</span>}
          </div>
          
          <h1 className="text-3xl font-bold mb-4">{product.name}</h1>
          
          <div className="flex items-center gap-2 mb-4">
            <span className="text-yellow-500 text-xl">⭐</span>
            <span className="text-lg font-semibold">{product.rating}</span>
            <span className="text-gray-400">({product.reviews.toLocaleString()} reviews)</span>
          </div>
          
          {/* FİYAT ALANI - quantity değiştikçe güncellenir */}
          <div className="mb-6">
            <span className="text-3xl text-gray-400 line-through mr-3">${product.oldPrice}</span>
            <span className="text-4xl font-bold text-orange-500">${currentTotalPrice}</span>
            <span className="text-sm text-gray-500 ml-2">(${product.price} x {quantity})</span>
          </div>
          
          {/* QUANTITY - + - butonları */}
          <div className="mb-6">
            <label className="block text-gray-700 font-medium mb-2">Quantity:</label>
            <div className="flex items-center gap-4">
              <button 
                onClick={() => setQuantity(Math.max(1, quantity - 1))} 
                className="w-10 h-10 bg-gray-200 rounded-full text-xl hover:bg-gray-300 transition"
              >
                −
              </button>
              <span className="text-xl font-semibold w-12 text-center">{quantity}</span>
              <button 
                onClick={() => setQuantity(quantity + 1)} 
                className="w-10 h-10 bg-gray-200 rounded-full text-xl hover:bg-gray-300 transition"
              >
                +
              </button>
            </div>
          </div>

          <div className="flex gap-4 flex-wrap">
            <button onClick={handleAddToCart} className="flex-1 bg-orange-500 text-white py-3 rounded-xl font-semibold hover:bg-orange-600 transition">
              🛒 Add to Cart ({quantity})
            </button>
            <button onClick={handleBuyNow} className="flex-1 bg-green-500 text-white py-3 rounded-xl font-semibold hover:bg-green-600 transition">
              💳 Buy Now
            </button>
          </div>

          <div className="mt-8 border-t pt-6">
            <h3 className="font-bold text-lg mb-3">Product Details</h3>
            <ul className="space-y-2 text-gray-600">
              <li>✓ Brand: {product.brand || "Premium"}</li>
              <li>✓ Category: {product.category}</li>
              <li>✓ Free Shipping on orders over $500</li>
              <li>✓ 30-Day Money Back Guarantee</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  );
};

export default ProductDetail;
</file>

